generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  trees     Tree[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tree {
  id                String                                @id @default(uuid())
  species           String
  locationName      String?
  // Geographical Point (Longitude, Latitude)
  coordinates       Unsupported("geometry(Point, 4326)")?
  dateField         String?
  totalHeight       String?
  firstBranchHeight String?
  dap               String?
  generalState      String?
  hasBalance        String?
  structureIssue    String?
  pestType          String?
  pestIntensity     String?
  affectedPart      String?
  injuryType        String?
  ecologyIndicators String?
  phenology         String?
  electricalWiring  String?
  userId            String
  user              User                                  @relation(fields: [userId], references: [id])
  createdAt         DateTime                              @default(now())
  updatedAt         DateTime                              @updatedAt

  @@index([coordinates], name: "tree_coordinates_idx", type: Gist)
}
